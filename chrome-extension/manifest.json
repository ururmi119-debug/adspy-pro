{
  "manifest_version": 3,
  "name": "AdRadar v5.1.7",
  "version": "5.1.7",
  "description": "Meta Ad Library Intelligence - POD & E-commerce Ad Analyzer",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://web.facebook.com/*",
    "https://adspy-pro-vc7w.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/ads/library/*",
        "https://facebook.com/ads/library/*",
        "https://web.facebook.com/ads/library/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "icons": {
    "48": "icon48.png"
  }
}
